{
  "manifest_version": 3,
  "name": "AI Bot Extension",
  "version": "1.0.0",
  "description": "Comprehensive AI assistant with 15+ specialized skills for background tasks, server integration, mail management, content creation, and more",
  
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "background",
    "offscreen",
    "downloads",
    "clipboardRead",
    "clipboardWrite",
    "notifications",
    "desktopCapture",
    "tabCapture",
    "cookies",
    "webNavigation",
    "contextMenus"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "*://*.google.com/*",
    "*://*.gmail.com/*",
    "*://*.outlook.com/*",
    "*://*.venmail.com/*",
    "*://*.telegram.org/*",
    "*://*.web.whatsapp.com/*",
    "*://*.docs.google.com/*",
    "*://*.slides.google.com/*",
    "*://*.youtube.com/*"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/universal-handler.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["vendors.js", "698.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Bot Extension",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "shared/*", "skills/application-writing/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
