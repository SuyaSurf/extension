{
  "manifest_version": 3,
  "name": "SuyaSurf Chrome Assistant",
  "version": "1.0.0",
  "description": "Comprehensive AI assistant with 15+ specialized skills for background tasks, server integration, mail management, content creation, and more",
  
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "background",
    "offscreen",
    "downloads",
    "clipboardRead",
    "clipboardWrite",
    "notifications",
    "desktopCapture",
    "tabCapture",
    "cookies",
    "webNavigation",
    "contextMenus",
    "identity"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "*://*.google.com/*",
    "*://*.gmail.com/*",
    "*://*.outlook.com/*",
    "*://*.venmail.com/*",
    "*://*.telegram.org/*",
    "*://*.web.whatsapp.com/*",
    "*://*.docs.google.com/*",
    "*://*.slides.google.com/*",
    "*://*.youtube.com/*",
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/universal-handler.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["vendors.js", "698.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/calendar.events.readonly"
    ]
  },
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Bot Extension",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "shared/*",
        "skills/application-writing/*",
        "skills/qa-testing/*",
        "vendors/*",
        "698/*",
        "newtab/*",
        "settings/*",
        "content-script/*",
        "popup/*",
        "offscreen/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
