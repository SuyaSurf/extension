# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://suyasurf:password@localhost:5432/suyasurf
POSTGRES_PASSWORD=your_secure_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Security
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_characters
ENCRYPTION_KEY=your_32_character_encryption_key_for_notes

# External API Keys
OPENAI_API_KEY=sk-your-openai-api-key

# Kokoro TTS Configuration
KOKORO_MODEL_PATH=/app/models/kokoro
KOKORO_WORKERS=2
KOKORO_VOICE_DEFAULT=onyx-best

# File Storage
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=100MB

# API Keys for service-to-service communication
API_KEYS=service-key-1,service-key-2

# Whisper Configuration
WHISPER_WORKERS=2
WHISPER_MODEL=base
CUDA_VISIBLE_DEVICES=0

# TTS Configuration
TTS_CACHE_TTL=604800
TTS_MAX_TEXT_LENGTH=4096

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/app/logs

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# Monitoring
GRAFANA_PASSWORD=your_grafana_password

# Development
DEBUG=false
